{
  "name": "talizen-cli",
  "version": "0.1.10",
  "description": "Talizen CLI for syncing local site code with Talizen.",
  "license": "MIT",
  "homepage": "https://github.com/talizen/talizen-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talizen/talizen-cli.git"
  },
  "bugs": {
    "url": "https://github.com/talizen/talizen-cli/issues"
  },
  "bin": {
    "talizen": "bin/talizen.js"
  },
  "scripts": {
    "prepare:npm-binaries": "node scripts/prepare-npm-binaries.js",
    "test:npm": "node scripts/install.js --check"
  },
  "files": [
    "bin/",
    "scripts/",
    "vendor/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
